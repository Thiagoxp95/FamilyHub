{
  "name": "family-hub",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.15.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@family-hub/electron",
    "dev:packed": "npm --workspace @family-hub/electron run dev:packed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
  }
}
